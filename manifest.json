{
  "manifest_version": 3,
  "name": "Poetic Ad Blocker",
  "version": "1.0",
  "description": "Replaces YouTube ads with classic sonnets.",
  "host_permissions": ["*://*.youtube.com/*", "https://poetrydb.org/*"],
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }

  ],
  "background": {
    "service_worker": "background.js"
  }
}
